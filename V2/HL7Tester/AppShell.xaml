<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HL7Tester.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HL7Tester"
    Title="HL7Tester">

    <TabBar Shell.TabBarIsVisible="False">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Network"
            ContentTemplate="{DataTemplate local:NetworkSettingsPage}"
            Route="NetworkSettingsPage" />
    </TabBar>

</Shell>
