<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HL7Tester.MainPage"
             Title="HL7Tester">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="20,16"
              ColumnSpacing="20"
              BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource OffBlack}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Spacing="2">
                <Label Text="HL7Tester"
                       TextColor="White"
                       FontSize="26"
                       FontAttributes="Bold" />
                <Label Text="HL7 messages generator"
                       TextColor="{AppThemeBinding Light={StaticResource SecondaryDarkText}, Dark={StaticResource Gray300}}"
                       FontSize="14" />
            </VerticalStackLayout>

            <Grid Grid.Column="1"
                  ColumnSpacing="8"
                  HorizontalOptions="End"
                  VerticalOptions="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0"
                       Text="Message Family"
                       TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray200}}"
                       FontAttributes="Bold"
                       VerticalTextAlignment="Center" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding AvailableMessageFamilies}"
                        SelectedItem="{Binding SelectedMessageFamily}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />

                <Label Grid.Column="2"
                       Text="Message Type"
                       Margin="8,0,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray200}}"
                       FontAttributes="Bold"
                       VerticalTextAlignment="Center" />
                <Picker Grid.Column="3"
                        ItemsSource="{Binding AvailableMessageTypes}"
                        SelectedItem="{Binding SelectedMessageType}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />
            </Grid>
        </Grid>

        <!-- Main content -->
        <ScrollView Grid.Row="1">
            <Grid Padding="20"
                  RowSpacing="12"
                  ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Patient identity -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Patient identity"
                               Style="{StaticResource SubHeadline}"
                               HorizontalOptions="Start" />

                        <Grid ColumnSpacing="10" RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding PatientIdLabel}" VerticalOptions="Center" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding PatientId}" Placeholder="Patient ID" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Admission number" VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding AdmissionNumber}" Placeholder="Admission number" />

                            <Label Grid.Row="2" Grid.Column="0" Text="New Patient ID" IsVisible="{Binding IsNewPatientIdVisible}" VerticalOptions="Center" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding NewPatientId}" IsVisible="{Binding IsNewPatientIdVisible}" Placeholder="A18/A40" />

                            <Label Grid.Row="3" Grid.Column="0" Text="Family name" VerticalOptions="Center" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding PatientFamilyName}" Placeholder="PID-5.1" />

                            <Label Grid.Row="4" Grid.Column="0" Text="Given name" VerticalOptions="Center" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding PatientGivenName}" Placeholder="PID-5.2" />

                            <Label Grid.Row="5" Grid.Column="0" Text="Birth date" VerticalOptions="Center" />
                            <Entry Grid.Row="5" Grid.Column="1" Text="{Binding BirthDate}" Placeholder="yyyyMMdd" />

                            <Label Grid.Row="6" Grid.Column="0" Text="Sex" VerticalOptions="Center" />
                            <Entry Grid.Row="6" Grid.Column="1" Text="{Binding Sex}" Placeholder="Sex" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Event and location -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnSpacing="10"
                              RowSpacing="6"
                              IsVisible="{Binding IsEventDateTimeVisible}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="400" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0"
                                   Text="Event"
                                   Style="{StaticResource SubHeadline}"
                                   VerticalOptions="Center" />

                            <Label Grid.Column="1"
                                   Text="EVN-6-1"
                                   TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray200}}"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="End"
                                   HorizontalOptions="End"
                                   VerticalTextAlignment="Center" />

                            <Entry Grid.Column="2"
                                   Text="{Binding EventDateTime}"
                                   Placeholder="yyyyMMddHHmm"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 IsVisible="{Binding IsEventDateTimeVisible}"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <Label Text="Patient location"
                               Style="{StaticResource SubHeadline}"
                               HorizontalOptions="Start" />

                        <Grid ColumnSpacing="10" RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="Unit" VerticalOptions="Center" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Unit}" Placeholder="PV1-3.1" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Room" VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Room}" Placeholder="PV1-3.2" />

                            <Label Grid.Row="2" Grid.Column="0" Text="Bed" VerticalOptions="Center" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Bed}" Placeholder="PV1-3.3" />

                            <Label Grid.Row="3" Grid.Column="0" Text="Facility" VerticalOptions="Center" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Facility}" Placeholder="PV1-3.4" />

                            <Label Grid.Row="4" Grid.Column="0" Text="Floor" VerticalOptions="Center" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding Floor}" Placeholder="PV1-3.8" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- OBX full width in ADT mode -->
                <Border Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Style="{StaticResource CardBorder}"
                        IsVisible="{Binding IsAdtMode}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="OBX segments"
                               Style="{StaticResource SubHeadline}"
                               HorizontalOptions="Start" />

                        <Grid ColumnSpacing="12" RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="OBX 1 - Type" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Obx1Type}" Placeholder="OBX-3-1" />

                            <Label Grid.Row="1" Grid.Column="0" Text="OBX 1 - Reason" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Obx1Reason}" Placeholder="OBX-5-1" />

                            <Label Grid.Row="2" Grid.Column="0" Text="OBX 2 - Type" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Obx2Type}" Placeholder="OBX-3-1" />

                            <Label Grid.Row="3" Grid.Column="0" Text="OBX 2 - Reason" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Obx2Reason}" Placeholder="OBX-5-1" />

                            <Label Grid.Row="4" Grid.Column="0" Text="OBX 3 - Type" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding Obx3Type}" Placeholder="OBX-3-1" />

                            <Label Grid.Row="5" Grid.Column="0" Text="OBX 3 - Reason" />
                            <Entry Grid.Row="5" Grid.Column="1" Text="{Binding Obx3Reason}" Placeholder="OBX-5-1" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- OBX half width in ORM/SIU mode -->
                <Border Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource CardBorder}"
                        IsVisible="{Binding IsNonAdtMode}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="OBX segments"
                               Style="{StaticResource SubHeadline}"
                               HorizontalOptions="Start" />

                        <Grid ColumnSpacing="12" RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="OBX 1 - Type" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Obx1Type}" Placeholder="OBX-3-1" />

                            <Label Grid.Row="1" Grid.Column="0" Text="OBX 1 - Reason" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Obx1Reason}" Placeholder="OBX-5-1" />

                            <Label Grid.Row="2" Grid.Column="0" Text="OBX 2 - Type" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Obx2Type}" Placeholder="OBX-3-1" />

                            <Label Grid.Row="3" Grid.Column="0" Text="OBX 2 - Reason" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Obx2Reason}" Placeholder="OBX-5-1" />

                            <Label Grid.Row="4" Grid.Column="0" Text="OBX 3 - Type" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding Obx3Type}" Placeholder="OBX-3-1" />

                            <Label Grid.Row="5" Grid.Column="0" Text="OBX 3 - Reason" />
                            <Entry Grid.Row="5" Grid.Column="1" Text="{Binding Obx3Reason}" Placeholder="OBX-5-1" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ORM fields -->
                <Border Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource CardBorder}"
                        IsVisible="{Binding IsOrmSectionVisible}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="ORM fields"
                               Style="{StaticResource SubHeadline}"
                               HorizontalOptions="Start" />

                        <Label Text="ORC segment"
                               FontAttributes="Bold" />

                        <Grid ColumnSpacing="10" RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="Order control (ORC-1)" VerticalOptions="Center" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding OrderControl}" Placeholder="NW" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Placer order number (ORC-2)" VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding OrmPlacerOrderNumber}" Placeholder="ORC-2 / OBR-2" />

                            <Label Grid.Row="2" Grid.Column="0" Text="Filler order number (ORC-3)" VerticalOptions="Center" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding OrmFillerOrderNumber}" Placeholder="ORC-3 / OBR-3" />

                            <Label Grid.Row="3" Grid.Column="0" Text="Order status (ORC-5)" VerticalOptions="Center" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding OrmOrderStatus}" Placeholder="Final / OBR-25" />

                            <Label Grid.Row="4" Grid.Column="0" Text="Requested date/time (ORC-7.4)" VerticalOptions="Center" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding OrmRequestedDateTime}" Placeholder="yyyyMMddHHmmss" />

                            <Label Grid.Row="5" Grid.Column="0" Text="Ordering provider ID (ORC-12.1)" VerticalOptions="Center" />
                            <Entry Grid.Row="5" Grid.Column="1" Text="{Binding OrmOrderingProviderId}" Placeholder="ORC-12.1" />

                            <Label Grid.Row="6" Grid.Column="0" Text="Ordering provider family (ORC-12.2)" VerticalOptions="Center" />
                            <Entry Grid.Row="6" Grid.Column="1" Text="{Binding OrmOrderingProviderFamilyName}" Placeholder="ORC-12.2" />

                            <Label Grid.Row="7" Grid.Column="0" Text="Ordering provider given (ORC-12.3)" VerticalOptions="Center" />
                            <Entry Grid.Row="7" Grid.Column="1" Text="{Binding OrmOrderingProviderGivenName}" Placeholder="ORC-12.3" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <Label Text="OBR segment"
                               FontAttributes="Bold" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Universal service ID (OBR-4)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding OrmUniversalServiceId}" Placeholder="OBR-4" />
                        </Grid>

                        <Label Text="OBR-2 / OBR-3 / OBR-16 / OBR-25 are synchronized from ORC values above."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <Label Text="DG1 segment"
                               FontAttributes="Bold" />

                        <Grid ColumnSpacing="10" RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="Diagnosis code (DG1-3.1)" VerticalOptions="Center" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding OrmDiagnosisCode}" Placeholder="DG1-3.1" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Diagnosis text (DG1-3.2)" VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding OrmDiagnosisText}" Placeholder="DG1-3.2" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- SIU fields -->
                <Border Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource CardBorder}"
                        IsVisible="{Binding IsSiuSectionVisible}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="SIU fields"
                               Style="{StaticResource SubHeadline}"
                               HorizontalOptions="Start" />

                        <Label Text="SCH segment"
                               FontAttributes="Bold" />

                        <Grid ColumnSpacing="10" RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="Placer appointment ID (SCH-1)" VerticalOptions="Center" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding SiuPlacerAppointmentId}" Placeholder="SCH-1" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Filler appointment ID (SCH-2)" VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding SiuFillerAppointmentId}" Placeholder="SCH-2" />

                            <Label Grid.Row="2" Grid.Column="0" Text="Occurrence number (SCH-6)" VerticalOptions="Center" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding SiuOccurrenceNumber}" Placeholder="SCH-6" />

                            <Label Grid.Row="3" Grid.Column="0" Text="Appointment type (SCH-7)" VerticalOptions="Center" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding SiuAppointmentType}" Placeholder="SCH-7" />

                            <Label Grid.Row="4" Grid.Column="0" Text="Appointment reason (SCH-8)" VerticalOptions="Center" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding SiuAppointmentReason}" Placeholder="SCH-8" />

                            <Label Grid.Row="5" Grid.Column="0" Text="Start date/time (SCH-11.4)" VerticalOptions="Center" />
                            <Entry Grid.Row="5" Grid.Column="1" Text="{Binding SiuAppointmentStartDateTime}" Placeholder="yyyyMMddHHmmss" />

                            <Label Grid.Row="6" Grid.Column="0" Text="End date/time (SCH-11.5)" VerticalOptions="Center" />
                            <Entry Grid.Row="6" Grid.Column="1" Text="{Binding SiuAppointmentEndDateTime}" Placeholder="yyyyMMddHHmmss" />

                            <Label Grid.Row="7" Grid.Column="0" Text="Duration (SCH-10 / SCH-11.3)" VerticalOptions="Center" />
                            <Entry Grid.Row="7" Grid.Column="1" Text="{Binding SiuAppointmentDuration}" Placeholder="SCH-10 / SCH-11.3" />

                            <Label Grid.Row="8" Grid.Column="0" Text="Duration units (SCH-11.2)" VerticalOptions="Center" />
                            <Entry Grid.Row="8" Grid.Column="1" Text="{Binding SiuAppointmentDurationUnits}" Placeholder="m" />

                            <Label Grid.Row="9" Grid.Column="0" Text="Appointment status (SCH-22)" VerticalOptions="Center" />
                            <Entry Grid.Row="9" Grid.Column="1" Text="{Binding SiuAppointmentStatus}" Placeholder="SCH-22" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <Label Text="AIG segment"
                               FontAttributes="Bold" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Resource ID (AIG-4.1)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuGeneralResourceId}" Placeholder="AIG-4.1" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Resource name (AIG-4.2)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuGeneralResourceName}" Placeholder="AIG-4.2" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Resource type (AIG-5.1)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuGeneralResourceType}" Placeholder="AIG-5.1" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <Label Text="AIL segment"
                               FontAttributes="Bold" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Location code (AIL-4.1)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuLocationCode}" Placeholder="AIL-4.1" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Location description (AIL-4.2)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuLocationDescription}" Placeholder="AIL-4.2" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Location site (AIL-4.3)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuLocationSite}" Placeholder="AIL-4.3" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <Label Text="AIP segment"
                               FontAttributes="Bold" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Personnel ID (AIP-4.1)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuPersonnelId}" Placeholder="AIP-4.1" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Personnel family (AIP-4.2)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuPersonnelFamilyName}" Placeholder="AIP-4.2" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Personnel given (AIP-4.3)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuPersonnelGivenName}" Placeholder="AIP-4.3" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="Personnel role (AIP-5.1)" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding SiuPersonnelRole}" Placeholder="AIP-5.1" />
                        </Grid>

                        <Label Text="RGS segment is generated automatically from SIU resource groups."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Generated message and send log -->
                <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource CardBorder}">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="8" ZIndex="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0"
                                   Text="Generated HL7 message"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalOptions="Start" />

                            <Button Grid.Column="1"
                                    Text="Copy"
                                    HorizontalOptions="End"
                                    ZIndex="2"
                                    Clicked="OnCopyMessageClicked" />
                        </Grid>

                        <Editor Grid.Row="1"
                                Text="{Binding GeneratedMessage}"
                                AutoSize="TextChanges"
                                HeightRequest="200"
                                ZIndex="0"
                                IsReadOnly="False" />

                        <BoxView Grid.Row="2"
                                 HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <Grid Grid.Row="3" RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Send log"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalOptions="Start" />

                            <Button Grid.Row="0" Grid.Column="2"
                                    Text="Logs"
                                    HorizontalOptions="End"
                                    ZIndex="2"
                                    Clicked="OnOpenLogsClicked" />

                            <Editor Grid.Row="1" Grid.ColumnSpan="3"
                                    Text="{Binding SendLog}"
                                    AutoSize="TextChanges"
                                    HeightRequest="100"
                                    ZIndex="0"
                                    IsReadOnly="True" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollView>

        <!-- Bottom action bar -->
        <Grid Grid.Row="2"
              Padding="16,8"
              ColumnSpacing="12"
              BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Text="Generate HL7"
                    Command="{Binding GenerateCommand}" />

            <Button Grid.Column="1"
                    Text="Send HL7"
                    Command="{Binding SendCommand}" />

            <Button Grid.Column="2"
                    Text="Settings"
                    Clicked="OnSettingsClicked" />
        </Grid>
    </Grid>

</ContentPage>
