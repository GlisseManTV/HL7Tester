<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HL7Tester.MainPage"
             Title="HL7Tester">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Bandeau supérieur avec titre + sélection du type de message + EVN-6-1 -->
        <Grid Grid.Row="0"
              Padding="20,16"
              ColumnSpacing="20"
              BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource OffBlack}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Spacing="2">
                <Label Text="HL7Tester"
                       TextColor="White"
                       FontSize="26"
                       FontAttributes="Bold" />
                <Label Text="HL7 messages generator"
                       TextColor="{AppThemeBinding Light={StaticResource SecondaryDarkText}, Dark={StaticResource Gray300}}"
                       FontSize="14" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="6"
                                 HorizontalOptions="End"
                                 VerticalOptions="Center">
                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="600" />
                    </Grid.ColumnDefinitions>

                    <!-- Type de message à droite -->
                    <Label Grid.Column="0"
                           Text="Message Type"
                           TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray200}}"
                           FontAttributes="Bold"
                           VerticalTextAlignment="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding AvailableMessageTypes}"
                            SelectedItem="{Binding SelectedMessageType}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />
                </Grid>
            </VerticalStackLayout>
        </Grid>

        <!-- Contenu principal en 2 colonnes -->
        <ScrollView Grid.Row="1">
            <Grid Padding="20"
                  RowSpacing="12"
                  ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Identité patient -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Patient identity"
                               Style="{StaticResource SubHeadline}"
                               HorizontalOptions="Start"/>

                        <Grid ColumnSpacing="10" RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding PatientIdLabel}" VerticalOptions="Center" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding PatientId}" Placeholder="Patient ID" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Admission number" VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding AdmissionNumber}" Placeholder="Admission number" />

                            <Label Grid.Row="2" Grid.Column="0" Text="New Patient ID" IsVisible="{Binding IsNewPatientIdVisible}" VerticalOptions="Center" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding NewPatientId}" IsVisible="{Binding IsNewPatientIdVisible}" Placeholder="A18/A40" />

                            <Label Grid.Row="3" Grid.Column="0" Text="Family name" VerticalOptions="Center" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding PatientFamilyName}" Placeholder="PID-5.1" />

                            <Label Grid.Row="4" Grid.Column="0" Text="Given name" VerticalOptions="Center" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding PatientGivenName}" Placeholder="PID-5.2" />

                            <Label Grid.Row="5" Grid.Column="0" Text="Birth date" VerticalOptions="Center" />
                            <Entry Grid.Row="5" Grid.Column="1" Text="{Binding BirthDate}" Placeholder="yyyyMMdd" />

                            <Label Grid.Row="6" Grid.Column="0" Text="Sex" VerticalOptions="Center" />
                            <Entry Grid.Row="6" Grid.Column="1" Text="{Binding Sex}" Placeholder="Sex" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Informations de séjour / localisation -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="8">
           

                        <Grid Grid.Row="0" ColumnSpacing="10" RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />                             
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" /> 
                                <ColumnDefinition Width="400" />                                                                

                            </Grid.ColumnDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" 
                            Text="Event"
                            Style="{StaticResource SubHeadline}"
                            HorizontalOptions="Start" />
                            <Label Grid.Row="0" Grid.Column="1"
                                Text="EVN-6-1"
                                TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray200}}"
                                FontAttributes="Bold"
                                HorizontalTextAlignment="End"
                                HorizontalOptions="End"
                                VerticalTextAlignment="Center" />

                            <Entry Grid.Row="0" Grid.Column="2"
                                Text="{Binding EventDateTime}"
                                Placeholder="yyyyMMddHHmm"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />

                        </Grid>
                            <BoxView Grid.Row="2"
                                    HeightRequest="1"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />         
                            <Label Text="Patient location"
                                Style="{StaticResource SubHeadline}"
                                HorizontalOptions="Start" />

                        <Grid Grid.Row="1" ColumnSpacing="10" RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="Unit" VerticalOptions="Center"/>
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Unit}" Placeholder="PV1-3.1" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Room" VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Room}" Placeholder="PV1-3.2" />

                            <Label Grid.Row="2" Grid.Column="0" Text="Bed" VerticalOptions="Center" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Bed}" Placeholder="PV1-3.3" />

                            <Label Grid.Row="3" Grid.Column="0" Text="Facility" VerticalOptions="Center" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Facility}" Placeholder="PV1-3.4" />

                            <Label Grid.Row="4" Grid.Column="0" Text="Floor" VerticalOptions="Center" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding Floor}" Placeholder="PV1-3.8" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Bloc OBX -->
                <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="OBX segments"
                               Style="{StaticResource SubHeadline}"
                               HorizontalOptions="Start" />

                        <Grid ColumnSpacing="12" RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <!-- OBX 1 -->
                            <Label Grid.Row="0" Grid.Column="0" Text="OBX 1 - Type" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Obx1Type}" Placeholder="OBX-3-1" />

                            <Label Grid.Row="1" Grid.Column="0" Text="OBX 1 - Reason" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Obx1Reason}" Placeholder="OBX-5-1" />

                            <!-- OBX 2 -->
                            <Label Grid.Row="2" Grid.Column="0" Text="OBX 2 - Type" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Obx2Type}" Placeholder="OBX-3-1" />

                            <Label Grid.Row="3" Grid.Column="0" Text="OBX 2 - Reason" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Obx2Reason}" Placeholder="OBX-5-1" />

                            <!-- OBX 3 -->
                            <Label Grid.Row="4" Grid.Column="0" Text="OBX 3 - Type" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding Obx3Type}" Placeholder="OBX-3-1" />

                            <Label Grid.Row="5" Grid.Column="0" Text="OBX 3 - Reason" />
                            <Entry Grid.Row="5" Grid.Column="1" Text="{Binding Obx3Reason}" Placeholder="OBX-5-1" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Message généré + logs d'envoi -->
                <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource CardBorder}">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Zone message généré (éditable) -->
                        <Grid Grid.Row="0" ColumnSpacing="8" ZIndex="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0"
                                   Text="Generated HL7 message"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalOptions="Start" />

                            <Button Grid.Column="1"
                                    Text="Copy"
                                    HorizontalOptions="End"
                                    ZIndex="2"
                                    Clicked="OnCopyMessageClicked" />
                        </Grid>

                        <Editor Grid.Row="1"
                                Text="{Binding GeneratedMessage}"
                                AutoSize="TextChanges"
                                HeightRequest="200"
                                ZIndex="0"
                                IsReadOnly="False" />

                        <!-- Séparateur visuel -->
                        <BoxView Grid.Row="2"
                                 HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <!-- Zone logs d'envoi séparée -->
                        <Grid Grid.Row="3" RowSpacing="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Send log"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalOptions="Start" />

                            <!-- Bouton pour ouvrir le fichier de logs applicatifs -->
                            <Button Grid.Row="0" Grid.Column="2"
                                    Text="Logs"
                                    HorizontalOptions="End"
                                    ZIndex="2"
                                    Clicked="OnOpenLogsClicked" />

                            <Editor Grid.Row="1" Grid.ColumnSpan="3"
                                    Text="{Binding SendLog}"
                                    AutoSize="TextChanges"
                                    HeightRequest="100"
                                    ZIndex="0"
                                    IsReadOnly="True" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollView>

        <!-- Bandeau inférieur avec actions principales + accès aux paramètres réseau -->
        <Grid Grid.Row="2"
              Padding="16,8"
              ColumnSpacing="12"
              BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Text="Generate HL7"
                Command="{Binding GenerateCommand}" />

            <Button
                Grid.Column="1"
                Text="Send HL7"
                Command="{Binding SendCommand}" />

            <!-- Accès direct à la page de configuration réseau -->
            <Button
                Grid.Column="2"
                Text="Settings"
                Clicked="OnSettingsClicked" />
        </Grid>
    </Grid>

</ContentPage>
