<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HL7Tester.NetworkSettingsPage"
             Title="Network Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Network configuration" Style="{StaticResource Headline}" />

            <!-- Carte paramètres réseau -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="8">
                    <Grid RowSpacing="8" ColumnSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Text="IP address" />
                        <Entry Grid.Row="0" Grid.Column="1"
                               Text="{Binding IpAddress}"
                               Keyboard="Numeric" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Port" />
                        <Entry Grid.Row="1" Grid.Column="1"
                               Text="{Binding Port}"
                               Keyboard="Numeric" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Log level" />
                        <Picker Grid.Row="2" Grid.Column="1"
                                ItemsSource="{Binding AvailableLogLevels}"
                                SelectedItem="{Binding SelectedLogLevel}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Auto-update" />
                        <Switch Grid.Row="3" Grid.Column="1"
                                IsToggled="{Binding AutoUpdateCheck}" />

                        <Button Grid.Row="4" Grid.ColumnSpan="2"
                                Text="Save configuration"
                                Command="{Binding SaveCommand}"
                                HorizontalOptions="Fill" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Carte historique des connexions -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="History" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding HistoryEntries}"
                                    HeightRequest="160">
                        <CollectionView.EmptyView>
                            <Label Text="No previous connections yet." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8" ColumnSpacing="8">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectHistoryEntryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <Label Text="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Bouton de retour à la page principale -->
            <Button Text="Home"
                    HorizontalOptions="End"
                    Clicked="OnHomeClicked" />

            <!-- Version de l'application -->
            <Label Text="{Binding AssemblyVersion}"
                   HorizontalOptions="Center"
                   FontSize="Small"
                   TextColor="{DynamicResource Primary}" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
